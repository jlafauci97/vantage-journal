generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH / USERS ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  coverImage    String?
  bio           String?   @db.Text
  workplace     String?   @db.VarChar(200)
  interests     String?   @db.Text
  viewpoints    String?   @db.Text
  hashedPassword String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  following     Follow[]       @relation("UserFollowing")
  followers     Follow[]       @relation("UserFollowers")
  likes         Like[]
  saves         Save[]
  reactions     Reaction[]
  notifications Notification[] @relation("NotificationReceiver")
  sentNotifs    Notification[] @relation("NotificationSender")
  comments      Comment[]
  articleViews  ArticleView[]
  articles      Article[]      @relation("ArticleAuthor")
  votes         Vote[]
  reposts       Repost[]
  commentLikes  CommentLike[]

  @@index([email])
}

enum Role {
  USER
  ADMIN
}

// ─── SOCIAL ─────────────────────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ─── CONTENT ────────────────────────────────────────────────────

model Perspective {
  id          String              @id @default(cuid())
  name        String              @unique
  slug        String              @unique
  category    PerspectiveCategory
  description String?             @db.Text
  color       String?
  createdAt   DateTime            @default(now())

  articles Article[]

  @@index([category])
  @@index([slug])
}

enum PerspectiveCategory {
  POLITICS
  LIFESTYLE
  RELIGION
  NATIONALITY
  ECONOMICS
  PHILOSOPHY
}

model Topic {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String?     @db.Text
  imageUrl    String?
  sourceUrl   String?
  status      TopicStatus @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  articles Article[]

  @@index([status])
  @@index([createdAt])
  @@index([slug])
}

enum TopicStatus {
  DRAFT
  GENERATING
  PUBLISHED
  ARCHIVED
}

model Article {
  id            String        @id @default(cuid())
  slug          String        @unique
  topicId       String?
  perspectiveId String?
  authorId      String?
  title         String
  summary       String        @db.Text
  content       String        @db.Text
  contentType   ContentType   @default(MARKDOWN)
  isAiGenerated Boolean       @default(true)
  imageUrl      String?
  status        ArticleStatus @default(DRAFT)
  viewCount     Int           @default(0)
  likeCount     Int           @default(0)
  shareCount    Int           @default(0)
  voteScore     Int           @default(0)
  repostCount   Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  topic       Topic?       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  perspective Perspective? @relation(fields: [perspectiveId], references: [id])
  author      User?        @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  likes       Like[]
  saves       Save[]
  reactions   Reaction[]
  comments    Comment[]
  views       ArticleView[]
  votes       Vote[]
  reposts     Repost[]

  @@unique([topicId, perspectiveId])
  @@index([topicId])
  @@index([perspectiveId])
  @@index([authorId])
  @@index([status])
  @@index([createdAt])
  @@index([viewCount])
  @@index([slug])
}

enum ContentType {
  MARKDOWN
  HTML
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

// ─── INTERACTIONS ───────────────────────────────────────────────

model ArticleView {
  id        String   @id @default(cuid())
  articleId String
  userId    String?
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([articleId, userId])
  @@index([articleId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([articleId])
}

model Save {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([articleId])
}

model Reaction {
  id        String       @id @default(cuid())
  userId    String
  articleId String
  type      ReactionType
  createdAt DateTime     @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId, type])
  @@index([articleId])
}

enum ReactionType {
  AGREE
  DISAGREE
  INTERESTING
  SURPRISED
  ANGRY
  LOVE
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  value     Int      // +1 or -1
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([articleId])
}

model Repost {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([articleId])
}

// ─── COMMENTS ───────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  content   String   @db.Text
  parentId  String?
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[]     @relation("CommentReplies")
  likes   CommentLike[]

  @@index([articleId])
  @@index([parentId])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

// ─── NOTIFICATIONS ──────────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  receiverId String
  senderId   String?
  type       NotificationType
  entityId   String?
  message    String?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  receiver User  @relation("NotificationReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender   User? @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([receiverId, read])
  @@index([createdAt])
}

enum NotificationType {
  NEW_FOLLOWER
  ARTICLE_LIKED
  ARTICLE_SAVED
  ARTICLE_REPOSTED
  NEW_TOPIC
  COMMENT_REPLY
}

// ─── BUILDINGS / RENTALS ────────────────────────────────────────────

model Building {
  id                 String   @id @default(cuid())
  fullAddress        String   @map("full_address")
  houseNumber        String?  @map("house_number")
  streetName         String?  @map("street_name")
  borough            String?
  city               String?  @default("New York")
  state              String?  @default("NY")
  zipCode            String?  @map("zip_code")
  slug               String   @unique
  latitude           Float?
  longitude          Float?
  overallScore       Int      @default(0) @map("overall_score")
  reviewCount        Int      @default(0) @map("review_count")
  violationCount     Int      @default(0) @map("violation_count")
  complaintCount     Int      @default(0) @map("complaint_count")
  litigationCount    Int      @default(0) @map("litigation_count")
  dobViolationCount  Int      @default(0) @map("dob_violation_count")
  crimeCount         Int      @default(0) @map("crime_count")
  bedbugReportCount  Int      @default(0) @map("bedbug_report_count")
  evictionCount      Int      @default(0) @map("eviction_count")
  permitCount        Int      @default(0) @map("permit_count")
  sidewalkShedCount  Int      @default(0) @map("sidewalk_shed_count")
  leadViolationCount Int      @default(0) @map("lead_violation_count")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  rents     BuildingRent[]
  amenities BuildingAmenity[]
  listings  BuildingListing[]

  @@index([borough])
  @@index([zipCode])
  @@index([slug])
  @@map("buildings")
}

model BuildingRent {
  id           String   @id @default(cuid())
  buildingId   String   @map("building_id")
  source       String   // streeteasy, zillow, rent_com, apartments_com
  bedrooms     Int      // 0 = studio
  minRent      Int?     @map("min_rent")
  maxRent      Int?     @map("max_rent")
  medianRent   Int?     @map("median_rent")
  listingCount Int      @default(0) @map("listing_count")
  scrapedAt    DateTime @default(now()) @map("scraped_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([buildingId, source, bedrooms])
  @@index([buildingId])
  @@map("building_rents")
}

model BuildingAmenity {
  id         String   @id @default(cuid())
  buildingId String   @map("building_id")
  source     String   // streeteasy, zillow, rent_com, apartments_com
  amenity    String
  category   String   // building, outdoor, fitness, parking, laundry, security, pet, storage, luxury, other
  scrapedAt  DateTime @default(now()) @map("scraped_at")
  createdAt  DateTime @default(now()) @map("created_at")

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([buildingId, source, amenity])
  @@index([buildingId])
  @@map("building_amenities")
}

model BuildingListing {
  id                 String    @id @default(cuid())
  buildingId         String    @map("building_id")
  source             String    // streeteasy, zillow, rent_com, apartments_com
  listingName        String?   @map("listing_name")
  listingUrl         String?   @map("listing_url")
  propertyType       String?   @map("property_type")
  priceMin           Int?      @map("price_min")
  priceMax           Int?      @map("price_max")
  priceText          String?   @map("price_text")
  bedMin             Int?      @map("bed_min")
  bedMax             Int?      @map("bed_max")
  bathMin            Int?      @map("bath_min")
  bathMax            Int?      @map("bath_max")
  sqftMin            Int?      @map("sqft_min")
  sqftMax            Int?      @map("sqft_max")
  bedText            String?   @map("bed_text")
  bathText           String?   @map("bath_text")
  sqftText           String?   @map("sqft_text")
  unitsAvailable     Int       @default(0) @map("units_available")
  unitsAvailableText String?   @map("units_available_text")
  availabilityStatus String?   @map("availability_status")
  managementCompany  String?   @map("management_company")
  verified           Boolean   @default(false)
  hasPriceDrops      Boolean   @default(false) @map("has_price_drops")
  listingViews       Int?      @map("listing_views")
  updatedAtSource    DateTime? @map("updated_at_source")
  floorPlans         Json      @default("[]") @map("floor_plans")
  bedPriceData       Json      @default("[]") @map("bed_price_data")
  officeHours        Json      @default("[]") @map("office_hours")
  scrapedAt          DateTime  @default(now()) @map("scraped_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([buildingId, source])
  @@index([buildingId])
  @@map("building_listings")
}
