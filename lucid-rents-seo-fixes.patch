-    },
-    sitemap: sitemaps,
-  };
-}
+import type { MetadataRoute } from "next";
+
+const BUILDINGS_PER_SITEMAP = 45000;
+
+async function getSitemapCount(): Promise<number> {
+  try {
+    const res = await fetch(
+      `${process.env.NEXT_PUBLIC_SUPABASE_URL}/rest/v1/buildings?select=id&limit=1&offset=0`,
+      {
+        headers: {
+          apikey: process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
+          Prefer: "count=exact",
+        },
+      }
+    );
+    const countHeader = res.headers.get("content-range");
+    const totalBuildings = countHeader
+      ? parseInt(countHeader.split("/")[1] || "0", 10)
+      : 50000;
+    // Sitemap 0 = static pages, 1..N = building batches
+    return 1 + Math.ceil(totalBuildings / BUILDINGS_PER_SITEMAP);
+  } catch {
+    // Fallback: assume a reasonable upper bound
+    return 16;
+  }
+}
+
+export default async function robots(): Promise<MetadataRoute.Robots> {
+  const count = await getSitemapCount();
+  const sitemaps: string[] = [];
+  for (let i = 0; i < count; i++) {
+    sitemaps.push(`https://lucidrents.com/sitemap/${i}.xml`);
+  }
+
+  return {
+    rules: [
+      {
+        userAgent: "*",
+        allow: "/",
+        disallow: ["/api/", "/dashboard/"],
+      },
+    ],
+    sitemap: sitemaps,
+  };
+}
